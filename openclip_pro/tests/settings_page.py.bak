import streamlit as st
import logging  # Import logging
from database import get_settings, save_setting  # Use DB functions

logger = logging.getLogger(__name__)

# Assuming ai_module is available in session state if needed for model lists
# from ai.ai_models import AIAnalysisModule # No need to import the class itself, access via session state


def show():
    """Display the general application settings page."""
    st.title("⚙️ Application Settings")
    st.caption("Configure default behaviors and analysis parameters for new projects.")

    # Get AI module instance and model registry from session state
    ai_module = st.session_state.get("ai_module")
    model_registry = st.session_state.get("model_registry")

    # Fetch current global settings from DB
    current_settings = get_settings()

    tab_gen, tab_analysis, tab_export, tab_advanced = st.tabs(
        ["General Defaults", "Analysis Defaults", "Export Defaults", "Advanced"]
    )

    with tab_gen:
        st.subheader("General Defaults")
        # Get current value safely with default
        default_project_name_value = current_settings.get(
            "default_project_name", "Project %Y-%m-%d"
        )
        default_project_name = st.text_input(
            "Default Project Name Template",
            value=default_project_name_value,
            help="Template for new project names. Use date/time format codes like %Y, %m, %d, %H, %M.",
        )

        st.subheader("Appearance (Requires App Restart)")
        st.warning(
            "Note: Theme and sidebar state settings typically require restarting the Streamlit application to take full effect."
        )

        # Theme setting
        theme_options = ["dark", "light"]
        current_theme_setting = current_settings.get("default_theme", "dark")
        # Ensure current setting is a valid option, fallback if not
        if current_theme_setting not in theme_options:
            current_theme_setting = "dark"
        theme_index = theme_options.index(current_theme_setting)
        theme = st.selectbox(
            "Theme", theme_options, index=theme_index, key="theme_selectbox"
        )

        # Initial Sidebar State (setting this in config.toml is more reliable)
        # Sidebar state is often controlled via st.set_page_config or config.toml
        # It's less common to make this a dynamic setting in a DB.
        # Keeping the previous note that this requires app restart.
        # sidebar_state_options = ["expanded", "collapsed", "auto"]
        # current_sidebar_state = current_settings.get("initial_sidebar_state", "expanded")
        # if current_sidebar_state not in sidebar_state_options: current_sidebar_state = "expanded"
        # sidebar_index = sidebar_state_options.index(current_sidebar_state)
        # sidebar_state = st.selectbox("Initial Sidebar State", sidebar_state_options, index=sidebar_index, key="sidebar_state_selectbox")

        if st.button("Save General Settings", key="save_gen_settings"):
            saved_any = False
            # save_setting returns True if a change was made
            if save_setting("default_project_name", default_project_name):
                saved_any = True
            if save_setting("default_theme", theme.lower()):
                saved_any = True
            # if save_setting("initial_sidebar_state", sidebar_state): saved_any = True

            if saved_any:
                st.success("General settings saved!")
                # Force a reload of settings into session state if needed immediately
                st.session_state.user_settings = get_settings()
                st.rerun()  # Rerun to show updated success message and potentially apply name format
            else:
                st.info("No changes detected in general settings.")

    with tab_analysis:
        st.subheader("Default Initial Analysis Parameters")
        st.caption("These values will pre-fill the 'Create New Project' form.")
        analysis_cols = st.columns(2)

        # Get current default analysis settings, converting from string
        default_clip_length_value = int(current_settings.get("default_clip_length", 60))
        default_frame_sample_rate_value = float(
            current_settings.get("default_frame_sample_rate", 2.5)
        )
        default_score_threshold_value = int(
            current_settings.get("default_score_threshold", 75)
        )

        with analysis_cols[0]:
            default_clip_length = st.slider(
                "Segment Length (s)",
                10,
                180,
                default_clip_length_value,
                5,
                key="set_def_clip_len",
            )
            default_frame_sample_rate = st.slider(
                "Frame Sample Rate (s)",
                0.5,
                10.0,
                default_frame_sample_rate_value,
                0.5,
                key="set_def_sample_rate",
            )
        with analysis_cols[1]:
            default_score_threshold = st.slider(
                "Score Threshold",
                0,
                100,
                default_score_threshold_value,
                5,
                key="set_def_score",
            )

            st.markdown("---")
            st.markdown("**Default AI Model for Analysis**")

            # Select default provider and model using the model registry
            if ai_module and model_registry:
                providers = model_registry.list_providers()
                if not providers:
                    st.warning("No AI providers available. Check dependencies.")
                    default_ai_provider = "None"
                    default_ai_model = "None"
                else:
                    # Get current provider from settings, fallback to first available
                    current_provider_setting = current_settings.get(
                        "default_ai_provider", providers[0]
                    )
                    if current_provider_setting not in providers:
                        current_provider_setting = providers[0]
                    prov_index = providers.index(current_provider_setting)

                    default_ai_provider = st.selectbox(
                        "Default AI Provider",
                        providers,
                        index=prov_index,
                        key="set_def_ai_provider",
                    )

                    models = model_registry.list_models_for_provider(
                        default_ai_provider
                    )
                    if not models:
                        st.warning(
                            f"No models found for {default_ai_provider}. Check API keys if required."
                        )
                        default_ai_model = "None"  # Set to None if no models
                    else:
                        # Get current model from settings for the selected provider, fallback to first
                        current_model_setting = current_settings.get(
                            "default_ai_model", models[0]
                        )
                        if current_model_setting not in models:
                            current_model_setting = models[0]
                        mod_index = models.index(current_model_setting)

                        default_ai_model = st.selectbox(
                            "Default AI Model",
                            models,
                            index=mod_index,
                            key="set_def_ai_model",
                        )
            else:
                st.warning(
                    "AI Module or Model Registry not loaded. Cannot select default AI model."
                )
                # Display current settings but disable selection
                st.text_input(
                    "Default AI Provider",
                    value=current_settings.get("default_ai_provider", "N/A"),
                    disabled=True,
                )
                st.text_input(
                    "Default AI Model",
                    value=current_settings.get("default_ai_model", "N/A"),
                    disabled=True,
                )
                # Ensure default_ai_provider/model variables are set even if disabled
                default_ai_provider = current_settings.get("default_ai_provider")
                default_ai_model = current_settings.get("default_ai_model")

        st.subheader("Image Processing for AI Analysis")
        img_proc_cols = st.columns(2)

        compression_quality_value = int(current_settings.get("compression_quality", 85))
        max_resolution_value = int(current_settings.get("max_resolution", 720))

        with img_proc_cols[0]:
            compression_quality = st.slider(
                "JPEG Quality (AI Input)",
                50,
                100,
                compression_quality_value,
                5,
                key="set_jpeg_qual",
                help="Quality setting when encoding frames sent to AI models.",
            )
        with img_proc_cols[1]:
            valid_resolutions = [
                256,
                480,
                512,
                720,
                1024,
                1080,
            ]  # Example options for max dimension
            # Ensure current value is in valid options, fallback if not
            if max_resolution_value not in valid_resolutions:
                # Find closest valid resolution if the saved one isn't in the list
                max_resolution_value = min(
                    valid_resolutions, key=lambda x: abs(x - max_resolution_value)
                )

            max_resolution = st.select_slider(
                "Max Resolution (AI Input)",
                options=valid_resolutions,
                value=max_resolution_value,
                key="set_max_res",
                help="Maximum dimension (width or height) for frames sent to AI. Larger images cost more and may hit token limits.",
            )

        st.subheader("Concurrency Settings")
        st.caption(
            "Adjust the number of workers used for different tasks. More workers may speed up processing but require more resources."
        )
        concurrency_cols = st.columns(4)

        max_workers_extraction_value = int(
            current_settings.get("max_workers_extraction", 4)
        )
        max_workers_encoding_value = int(
            current_settings.get("max_workers_encoding", 4)
        )
        max_workers_api_value = int(current_settings.get("max_workers_api", 8))
        max_workers_clip_gen_value = int(
            current_settings.get("max_workers_clip_gen", 4)
        )

        with concurrency_cols[0]:
            max_workers_extraction = st.number_input(
                "Frame Extract Workers",
                1,
                16,
                max_workers_extraction_value,
                1,
                key="set_conc_extract",
                help="Workers for reading frames from video files.",
            )
        with concurrency_cols[1]:
            max_workers_encoding = st.number_input(
                "Frame Encode Workers",
                1,
                16,
                max_workers_encoding_value,
                1,
                key="set_conc_encode",
                help="Workers for encoding extracted frames to JPEG/base64.",
            )
        with concurrency_cols[2]:
            max_workers_api = st.number_input(
                "Initial Analysis API Workers",
                1,
                16,
                max_workers_api_value,
                1,
                key="set_conc_api",
                help="Workers for sending frames/prompts to AI for initial analysis.",
            )
        with concurrency_cols[3]:
            max_workers_clip_gen = st.number_input(
                "Clip Generation Workers",
                1,
                16,
                max_workers_clip_gen_value,
                1,
                key="set_conc_clipgen",
                help="Workers for running ffmpeg to generate clip video files.",
            )

        if st.button("Save Analysis Defaults", key="save_analysis_settings"):
            saved_any = False
            if save_setting("default_clip_length", str(default_clip_length)):
                saved_any = True
            if save_setting(
                "default_frame_sample_rate", str(default_frame_sample_rate)
            ):
                saved_any = True
            if save_setting("default_score_threshold", str(default_score_threshold)):
                saved_any = True
            if (
                ai_module
                and default_ai_provider != "None"
                and default_ai_model != "None"
            ):  # Only save AI model settings if selection was possible and valid
                if save_setting("default_ai_provider", default_ai_provider):
                    saved_any = True
                if save_setting("default_ai_model", default_ai_model):
                    saved_any = True
            elif ai_module:
                # If providers/models became unavailable, clear the settings? Or keep? Let's keep them but log a warning.
                logger.warning(
                    "Default AI Provider/Model selected might be unavailable, settings not saved."
                )

            if save_setting("compression_quality", str(compression_quality)):
                saved_any = True
            if save_setting("max_resolution", str(max_resolution)):
                saved_any = True
            if save_setting("max_workers_extraction", str(max_workers_extraction)):
                saved_any = True
            if save_setting("max_workers_encoding", str(max_workers_encoding)):
                saved_any = True
            if save_setting("max_workers_api", str(max_workers_api)):
                saved_any = True
            if save_setting("max_workers_clip_gen", str(max_workers_clip_gen)):
                saved_any = True

            if saved_any:
                st.success("Default analysis settings saved!")
                st.session_state.user_settings = (
                    get_settings()
                )  # Reload settings into state
                st.rerun()
            else:
                st.info("No changes detected in analysis settings.")

    with tab_export:
        st.subheader("Default Export Settings")
        st.caption("These settings determine the default options when exporting clips.")
        valid_formats = ["web_optimized", "high_quality", "copy_only"]
        current_format = current_settings.get("export_format", "web_optimized")
        if current_format not in valid_formats:
            current_format = "web_optimized"
        format_index = valid_formats.index(current_format)
        export_format = st.selectbox(
            "Default Clip Encoding Format",
            valid_formats,
            index=format_index,
            key="set_def_export_fmt",
            help="Default encoding for generated clip video files. 'copy_only' is fastest but may have compatibility issues.",
        )
        st.caption(
            "Note: Platform-specific export optimizations are available on the Project Export page."
        )

        if st.button("Save Export Defaults", key="save_export_settings"):
            if save_setting("export_format", export_format):
                st.success("Default export settings saved!")
                st.session_state.user_settings = (
                    get_settings()
                )  # Reload settings into state
                st.rerun()
            else:
                st.info("No changes detected in export settings.")

    with tab_advanced:
        st.subheader("Advanced Settings")
        st.warning("🚧 No advanced settings are currently available.")
        # Future: ffmpeg path, logging level, feature flags etc.
        # Maybe clear cache buttons?
        # if st.button("Clear Streamlit Cache"):
        #     # Streamlit doesn't have a public API for clearing @st.cache_data / @st.cache_resource programmatically
        #     # This button is illustrative. Need to restart the app for many cache changes.
        #      st.info("Clearing Streamlit cache requires restarting the app.")
