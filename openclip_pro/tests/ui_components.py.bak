# Contains UI generation functions related to AI configuration
import logging
import streamlit as st
from typing import Dict

# Import specific classes needed, not the whole module if possible
# Ensure correct import paths
from ai.ai_models import ModelRegistry, APIKeyManager  # Import AIAnalysisModule

# Set up logger
logger = logging.getLogger(__name__)

# Constants for session state keys used by the AI UI components
SESSION_KEY_AI_UI_PREFIX = "ai_ui_state_"  # Prefix to avoid key collisions
SESSION_KEY_ACTIVE_PROVIDER = SESSION_KEY_AI_UI_PREFIX + "active_provider"
SESSION_KEY_ACTIVE_MODEL = SESSION_KEY_AI_UI_PREFIX + "active_model"
SESSION_KEY_BOARD_ENABLED = SESSION_KEY_AI_UI_PREFIX + "board_enabled"
SESSION_KEY_BOARD_MEMBERS = SESSION_KEY_AI_UI_PREFIX + "board_members"
SESSION_KEY_BOARD_TASKS = SESSION_KEY_AI_UI_PREFIX + "board_tasks"
SESSION_KEY_CHAIRPERSON = SESSION_KEY_AI_UI_PREFIX + "chairperson"


def create_model_selection_ui(
    model_registry: ModelRegistry, key_manager: APIKeyManager
) -> Dict:
    """
    Empty UI function to return an empty configuration dictionary.
    The primary analysis and board configuration have been removed from the sidebar.

    Args:
        model_registry: An instance of ModelRegistry.
        key_manager: An instance of APIKeyManager.

    Returns:
        Empty configuration dictionary.
    """
    # Keep state variables initialized but don't display any UI
    if SESSION_KEY_BOARD_ENABLED not in st.session_state:
        st.session_state[SESSION_KEY_BOARD_ENABLED] = False
    if SESSION_KEY_BOARD_MEMBERS not in st.session_state:
        st.session_state[SESSION_KEY_BOARD_MEMBERS] = []
    if SESSION_KEY_BOARD_TASKS not in st.session_state:
        st.session_state[SESSION_KEY_BOARD_TASKS] = [
            "viral_analysis",
            "monetization_analysis",
        ]
    if SESSION_KEY_CHAIRPERSON not in st.session_state:
        st.session_state[SESSION_KEY_CHAIRPERSON] = None

    # Initialize session state for model selection
    if SESSION_KEY_ACTIVE_PROVIDER not in st.session_state:
        providers = model_registry.list_providers()
        if providers:
            st.session_state[SESSION_KEY_ACTIVE_PROVIDER] = providers[0]

    if SESSION_KEY_ACTIVE_MODEL not in st.session_state:
        provider = st.session_state.get(SESSION_KEY_ACTIVE_PROVIDER)
        if provider:
            models = model_registry.list_models_for_provider(provider)
            if models:
                st.session_state[SESSION_KEY_ACTIVE_MODEL] = models[0]

    # Return an empty configuration
    return {}


def create_api_key_management_ui(
    key_manager: APIKeyManager, model_registry: ModelRegistry
):
    """
    Render UI for API key management on a dedicated page.

    Args:
        key_manager: An instance of APIKeyManager.
        model_registry: An instance of ModelRegistry.
    """
    st.title("🔑 API Key Management")
    st.markdown(
        "Manage API keys for different AI providers. Keys are encrypted and stored locally."
    )
    st.warning(
        "Note: A hardcoded encryption key is used in this alpha version. **This is not secure for production or distributed applications.** For real-world use, the key must be managed securely (e.g., environment variable)."
    )

    # List providers that are known to require keys based on ModelRegistry
    providers_requiring_keys = sorted(
        [
            prov
            for prov, models in model_registry.KNOWN_MODELS.items()
            # Check if ANY model for this provider requires a key
            if any(info.get("requires_api_key", False) for info in models.values())
        ]
    )

    if not providers_requiring_keys:
        st.info("No configured providers require API keys.")
        st.caption(
            "Providers like Ollama typically run locally and do not need API keys."
        )
        return

    # Add a note about environment variables
    st.info(
        "API keys can also be provided via environment variables (e.g., `OPENAI_API_KEY`, `GEMINI_API_KEY`). Environment variables override saved keys."
    )

    # Check if Fernet is available before proceeding
    if not hasattr(key_manager, "fernet") or not key_manager.fernet:
        st.error("API Key encryption is not available. Cannot manage keys securely.")
        st.warning(
            "Please ensure the cryptography library is installed and Fernet initialization was successful (check logs)."
        )
        return

    # Display input/status for each provider requiring a key
    for provider in providers_requiring_keys:
        st.subheader(f"{provider.capitalize()} API Key")

        # Get the current key from the key manager (checks session, file, env)
        current_key = key_manager.get_key(provider)

        if current_key and provider.lower() != "ollama":  # Ollama key is a dummy value
            # Display masked key
            masked_key = (
                "*" * (len(current_key) - 4) + current_key[-4:]
                if len(current_key) > 4
                else "****"
            )
            st.success(f"API Key is set (ending in {masked_key}).")

            # Button to delete the key
            if st.button(
                f"Delete Key for {provider.capitalize()}", key=f"delete_{provider}_key"
            ):
                if key_manager.delete_key(provider):
                    st.success(
                        f"API Key for {provider.capitalize()} deleted successfully."
                    )
                    st.rerun()  # Rerun to update the UI state (show input field)
                else:
                    st.error(f"Failed to delete API key for {provider.capitalize()}.")

            # Expander to update the key
            with st.expander(f"Update API Key for {provider.capitalize()}"):
                new_key = st.text_input(
                    f"Enter New {provider.capitalize()} Key",
                    type="password",
                    key=f"update_input_{provider}",
                )
                if st.button("Save Updated Key", key=f"update_btn_{provider}"):
                    if new_key:
                        if key_manager.save_key(provider, new_key):
                            st.success(
                                f"API key for {provider.capitalize()} updated successfully!"
                            )
                            st.rerun()
                        else:
                            # save_key logs the error
                            st.error("Failed to save updated API key.")
                    else:
                        st.warning("Please enter the new API key.")

        elif provider.lower() == "ollama":
            # Ollama doesn't use API keys in the traditional sense
            st.info(
                f"{provider.capitalize()} typically runs locally and does not require an API key."
            )
            st.caption(
                "Ensure your Ollama server is running and accessible if using Ollama models."
            )
        else:
            # API key is not set
            st.warning(f"API Key for {provider.capitalize()} is not set.")
            new_key = st.text_input(
                f"Enter {provider.capitalize()} Key",
                type="password",
                key=f"input_{provider}",
            )
            if st.button(
                f"Save Key for {provider.capitalize()}", key=f"save_btn_{provider}"
            ):
                if new_key:
                    # Basic length validation
                    if len(new_key.strip()) < 10:
                        st.warning("API Key seems too short. Please double-check.")
                    # Save the new key
                    if key_manager.save_key(provider, new_key):
                        st.success(
                            f"API key for {provider.capitalize()} saved successfully!"
                        )
                        st.rerun()  # Rerun to update UI state (show masked key)
                    else:
                        # save_key logs the error
                        st.error("Failed to save API key.")
                else:
                    st.warning("Please enter an API key.")

        st.markdown("---")

    st.markdown(
        """
    **Note on Storage:** API keys saved here are encrypted using a key stored with the application code (INSECURE for distribution) and saved to `~/.openclip/api_keys.json`.
    Environment variables (e.g., `OPENAI_API_KEY`) are also checked and take precedence if set.
    """
    )
