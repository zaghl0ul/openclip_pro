# Setup logging
logger = logging.getLogger(__name__)

# Constants (moved/defined locally if not from config)
DEFAULT_MAX_TOKENS = 1000  # Increased default for more detailed analysis
DEFAULT_TEMPERATURE = 0.5
# DEFAULT_API_TIMEOUT = 120 # Timeout in seconds - kept locally here for AI specific calls

# Streamlit session state keys
SESSION_KEY_API_KEYS = "api_keys"  # Matches key used internally

# --- API Key Encryption ---
# CRITICAL SECURITY NOTE: The Fernet key used for encryption is hardcoded here.
# This provides encryption at rest on the file system but offers ZERO security
# if the attacker has access to the code itself.
# For alpha testing, this demonstrates the concept, but for any production
# deployment or distribution, this key MUST be managed securely (e.g., environment
# variable provided at runtime, or a user-provided password used to derive the key).
# DO NOT deploy applications with hardcoded keys like this in a real-world scenario.
try:
    # Attempt to use a key from an environment variable first, fallback to hardcoded
    _fernet_key = os.environ.get("OPENCLIP_FERNET_KEY")
    if _fernet_key:
        fernet = Fernet(_fernet_key.encode())
        logger.info("Using Fernet key from OPENCLIP_FERNET_KEY environment variable.")
    else:
        # WARNING: This hardcoded key is INSECURE for distributed applications.
        logger.warning(
            "Using hardcoded Fernet key. This is INSECURE for distributed builds."
        )
        fernet = Fernet(
            b"CD3eEKcH5P_G1yYtUXypMm5tmml9CGZPDHz4vPwh-y4="
        )  # Example hardcoded key
except Exception as e:
    logger.error(f"Failed to initialize Fernet encryption: {e}", exc_info=True)
    # If encryption fails, maybe disable saving/loading keys? Or run unencrypted?
    # Running unencrypted as a fallback might expose keys. Safer to disable.
    fernet = None  # Indicate encryption is not available


# Encryption helpers - check if fernet is initialized
def encrypt(data: str) -> str:
    if not fernet:
        logger.error("Fernet not initialized, cannot encrypt.")
        raise RuntimeError("Encryption is not available.")
    return fernet.encrypt(data.encode()).decode()


def decrypt(data: str) -> str:
    if not fernet:
        logger.error("Fernet not initialized, cannot decrypt.")
        raise RuntimeError("Encryption is not available.")
    return fernet.decrypt(data.encode()).decode()


##############################
# API Key Management
##############################
class APIKeyManager:
    """Secure API key management system."""

    def __init__(self, key_file=API_KEY_FILE):
        self.key_file = key_file
        # Initialize session state key if it doesn't exist
        if SESSION_KEY_API_KEYS not in st.session_state:
            st.session_state[SESSION_KEY_API_KEYS] = {}
        self._initialize_key_storage()

    def _initialize_key_storage(self):
        """Initialize session state from file storage."""
        if not fernet:
            logger.warning("Encryption not available. Skipping loading keys from file.")
            st.session_state[SESSION_KEY_API_KEYS] = (
                {}
            )  # Ensure empty if encryption failed
            return  # Cannot load encrypted keys

        # Ensure directory exists (already done in config, but safe retry)
        try:
            os.makedirs(os.path.dirname(self.key_file), exist_ok=True)
        except OSError as e:
            logger.error(
                f"Failed to create directory for API key file {self.key_file}: {e}",
                exc_info=True,
            )
            st.error(f"Error creating directory for API keys: {e}")
            st.session_state[SESSION_KEY_API_KEYS] = {}  # Reset
            return

        # Load saved keys if file exists
        if os.path.exists(self.key_file):
            try:
                with open(self.key_file, "r") as f:
                    encrypted_keys = json.load(f)
                    # Decrypt keys
                    api_keys = {}
                    for k, v in encrypted_keys.items():
                        try:
                            api_keys[k] = decrypt(v)
                        except Exception as decrypt_e:
                            logger.error(
                                f"Failed to decrypt key for provider {k}: {decrypt_e}. Skipping this key.",
                                exc_info=True,
                            )
                            # Continue with other keys
                st.session_state[SESSION_KEY_API_KEYS].update(api_keys)
                logger.info(f"Loaded {len(api_keys)} API keys from {self.key_file}")
            except (json.JSONDecodeError, OSError, Exception) as e:
                logger.error(
                    f"Error loading API keys from {self.key_file}: {e}", exc_info=True
                )
                st.warning(
                    f"Could not load API keys from file ({e}). Keys may need to be re-entered."
                )
                st.session_state[SESSION_KEY_API_KEYS] = (
                    {}
                )  # Reset to empty if file corrupted/unreadable
        else:
            logger.info(
                f"API key file not found at {self.key_file}. Will create if keys are saved."
            )

        # Also check environment variables on init and add to session state (without saving to file)
        env_keys = self._get_keys_from_env()
        if env_keys:
            logger.info(f"Found {len(env_keys)} API keys in environment variables.")
            # Add env keys to session state, prioritize file/session keys if conflict
            for provider, key in env_keys.items():
                if provider not in st.session_state[SESSION_KEY_API_KEYS]:
                    st.session_state[SESSION_KEY_API_KEYS][provider] = key

    def _get_keys_from_env(self) -> Dict[str, str]:
        """Helper to get API keys from common environment variables."""
        env_keys = {}
        # Map standard provider names to potential environment variable prefixes
        provider_env_map = {
            "openai": ["OPENAI_API_KEY", "OPENAI_KEY"],
            "anthropic": [
                "ANTHROPIC_API_KEY",
                "ANTHROPIC_KEY",
                "CLAUDE_API_KEY",
                "ANTHROPIC_API_KEY",
            ],  # Anthropic client uses ANTHROPIC_API_KEY env var
            "google": [
                "GOOGLE_API_KEY",
                "GEMINI_API_KEY",
            ],  # Google client uses GOOGLE_API_KEY env var
            "ollama": [],  # Ollama doesn't typically use an API key env var
            # Add others as needed
        }

        for provider, env_vars in provider_env_map.items():
            for env_var in env_vars:
                key = os.environ.get(env_var)
                if key:
                    env_keys[provider] = key  # Store the first one found
                    break  # Move to the next provider

        return env_keys

    def save_key(self, provider: str, api_key: str) -> bool:
        """Save an API key for a provider to session state and file."""
        if not fernet:
            st.error("Encryption is not available. Cannot save API keys securely.")
            return False
        if not provider or not api_key:
            logger.warning("Attempted to save empty provider or API key.")
            st.warning("Provider or API key cannot be empty.")
            return False

        provider = provider.lower()
        # Save to session state
        st.session_state.setdefault(SESSION_KEY_API_KEYS, {})[provider] = api_key
        logger.debug(f"API key for provider {provider} updated in session state.")

        # Save all keys (from session state) to file
        try:
            # Encrypt all keys currently in session state before saving
            encrypted_keys = {
                k: encrypt(v)
                for k, v in st.session_state[SESSION_KEY_API_KEYS].items()
                if v
            }  # Don't save empty keys
            with open(self.key_file, "w") as f:
                json.dump(encrypted_keys, f, indent=2)
            logger.info(
                f"API key for provider '{provider}' saved successfully to file."
            )
            return True
        except (
            OSError,
            TypeError,
            RuntimeError,
        ) as e:  # Catch RuntimeError if fernet is None/failed
            logger.error(
                f"Error saving API keys to {self.key_file}: {e}", exc_info=True
            )
            st.error(f"Error saving API keys to file: {e}")
            return False

    def get_key(self, provider: str) -> Optional[str]:
        """Get the API key for a provider (checks session, then env implicitly loaded)."""
        provider = provider.lower()
        # Keys are loaded into session state during initialization from file and env.
        # So, just checking session state is sufficient after init.
        key = st.session_state.get(SESSION_KEY_API_KEYS, {}).get(provider)

        # Add a specific check for Ollama - it generally doesn't use API keys
        if provider == "ollama":
            return "ollama_local_access"  # Return a dummy value indicating local access doesn't need a key

        if key:
            logger.debug(f"Retrieved API key for {provider} from session state.")
            return key
        else:
            # If not found, explicitly check env vars one more time as a safety net,
            # although _initialize_key_storage should cover this.
            env_keys = self._get_keys_from_env()
            if provider in env_keys:
                logger.info(
                    f"Retrieved API key for {provider} from environment variable (late check)."
                )
                st.session_state[SESSION_KEY_API_KEYS][provider] = env_keys[
                    provider
                ]  # Add to session state
                return env_keys[provider]

        logger.debug(f"API key for provider '{provider}' not found.")
        return None

    def delete_key(self, provider: str) -> bool:
        """Delete an API key for a provider from session and file."""
        if not fernet:
            st.error("Encryption is not available. Cannot delete API keys securely.")
            return False

        provider = provider.lower()
        key_deleted_from_session = False

        # Delete from session state
        if provider in st.session_state.get(SESSION_KEY_API_KEYS, {}):
            del st.session_state[SESSION_KEY_API_KEYS][provider]
            key_deleted_from_session = True
            logger.debug(f"API key for provider {provider} deleted from session state.")

        # Save the updated state to persistent storage (implicitly removes the key from the file)
        try:
            # Encrypt all keys remaining in session state and save
            encrypted_keys = {
                k: encrypt(v)
                for k, v in st.session_state.get(SESSION_KEY_API_KEYS, {}).items()
                if v
            }
            # If the file existed but is now empty, delete it
            if not encrypted_keys and os.path.exists(self.key_file):
                os.remove(self.key_file)
                logger.info(f"API key file {self.key_file} deleted as it is now empty.")
            elif encrypted_keys:
                with open(self.key_file, "w") as f:
                    json.dump(encrypted_keys, f, indent=2)
                logger.info(f"API key for provider '{provider}' removed from file.")

            # Return True if it was deleted from session, or if it wasn't in session
            # but the file operation implies it's gone.
            return True

        except (OSError, TypeError, RuntimeError) as e:
            logger.error(
                f"Error deleting API key from file {self.key_file}: {e}", exc_info=True
            )
            st.error(f"Error deleting API key from file: {e}")
            return False

    def list_providers_with_keys(self) -> List[str]:
        """Return a list of provider names for which we have API keys."""
        return sorted(list(st.session_state.get(SESSION_KEY_API_KEYS, {}).keys()))


##############################
# Provider-Specific Client Wrappers / Integrations (Optional but can simplify AIModelManager)
# Keeping GeminiIntegration for now, though direct integration is viable.
# Add basic wrappers for other clients if needed for complex provider specifics.
##############################


class GeminiIntegration:
    """Integration class for Google's Gemini API"""

    def __init__(self, api_key=None):
        # Note: gemini config is global, so init/key setting needs care
        # It might be safer to pass the key per call if genai.configure is problematic.
        # However, the async client pattern usually involves initializing the client once.
        self.api_key = api_key
        self.genai = genai  # Use the imported module
        self.initialized = False
        if self.genai and self.api_key:
            self._configure()
        elif not self.genai:
            logger.error(
                "google.generativeai module not imported. Cannot initialize Gemini."
            )
        else:
            logger.warning(
                "No Gemini API key provided during initialization. Gemini client not configured."
            )

    def _configure(self):
        """Configure the Gemini API client using the instance's API key."""
        if not self.genai or not self.api_key:
            return

        try:
            self.genai.configure(api_key=self.api_key)
            # Test configuration might involve a small API call, skipping for speed.
            self.initialized = True
            logger.info("Gemini API configured successfully.")
        except Exception as e:
            logger.error(f"Failed to configure Gemini API: {e}", exc_info=True)
            self.initialized = False

    def set_api_key(self, api_key):
        """Set or update the API key and reconfigure."""
        self.api_key = api_key
        self._configure()
        return self.initialized

    async def analyze_with_gemini(
        self,
        model_name: str,
        prompt: str,
        images: List[str] = None,  # List of base64 image strings
        temperature: float = DEFAULT_TEMPERATURE,
        max_tokens: int = DEFAULT_MAX_TOKENS,
        timeout: int = DEFAULT_API_TIMEOUT,
        format_type: str = "json",
    ) -> str:
        """Run analysis with Gemini model"""
        # Check initialization and API key availability before calling
        if not self.initialized or not self.genai or not self.api_key:
            logger.error("Gemini API not configured or key missing.")
            return "Error: Gemini API not configured or API key missing."

        try:
            # GenAI models are accessed via genai.GenerativeModel
            model = self.genai.GenerativeModel(model_name)

            # Prepare content parts for multimodal models
            content_parts = []
            if images:
                for img_base64 in images:
                    try:
                        # Decode base64 image data
                        img_bytes = base64.b64decode(img_base64)
                        content_parts.append(
                            {"mime_type": "image/jpeg", "data": img_bytes}
                        )
                    except Exception as img_err:
                        logger.error(
                            f"Error decoding image for Gemini: {img_err}", exc_info=True
                        )
                        # Decide how to handle: skip this image? Fail the call?
                        # For now, log and skip the problematic image.

            # Add text prompt part
            content_parts.append({"text": prompt})

            # Configure generation settings
            generation_config = self.genai.types.GenerationConfig(
                max_output_tokens=max_tokens,
                temperature=temperature,
            )

            # Safety settings (example, adjust as needed) - default is usually fine
            safety_settings = [
                {
                    "category": "HARM_CATEGORY_HARASSMENT",
                    "threshold": "BLOCK_MEDIUM_AND_ABOVE",
                },
                {
                    "category": "HARM_CATEGORY_HATE_SPEECH",
                    "threshold": "BLOCK_MEDIUM_AND_ABOVE",
                },
                {
                    "category": "HARM_CATEGORY_SEXUALLY_EXPLICIT",
                    "threshold": "BLOCK_MEDIUM_AND_ABOVE",
                },
                {
                    "category": "HARM_CATEGORY_DANGEROUS_CONTENT",
                    "threshold": "BLOCK_MEDIUM_AND_ABOVE",
                },
            ]

            # Run generation asynchronously
            # Need to handle timeout using asyncio.wait_for as the client method might not have a direct timeout parameter
            response = await asyncio.wait_for(
                model.generate_content_async(
                    content_parts,
                    generation_config=generation_config,
                    safety_settings=safety_settings,
                ),
                timeout=timeout,  # Use the provided timeout
            )

            # Check for safety blocks or empty response
            # GenAI response structure: response.candidates -> candidate.content -> parts
            if not response.candidates:
                prompt_feedback = response.prompt_feedback
                # Access block reason safely
                block_reason = "Unknown"
                if (
                    prompt_feedback
                    and hasattr(prompt_feedback, "block_reason")
                    and prompt_feedback.block_reason
                ):
                    block_reason = (
                        prompt_feedback.block_reason.name
                    )  # Enum name like SAFETY
                elif (
                    prompt_feedback
                    and hasattr(prompt_feedback, "safety_ratings")
                    and prompt_feedback.safety_ratings
                ):
                    # Check safety ratings for specific blocks
                    blocked_categories = [
                        r.category.name
                        for r in prompt_feedback.safety_ratings
                        if "BLOCK" in r.probability.name
                    ]
                    if blocked_categories:
                        block_reason = f"Safety Block ({', '.join(blocked_categories)})"

                logger.warning(
                    f"Gemini response blocked or empty for model {model_name}. Reason: {block_reason}"
                )
                return f"Error: Gemini response blocked (Reason: {block_reason})"

            # Extract text content from the response
            response_text = ""
            # Access content safely
            if response.candidates and len(response.candidates) > 0:
                candidate = response.candidates[0]
                if (
                    hasattr(candidate, "content")
                    and candidate.content
                    and hasattr(candidate.content, "parts")
                ):
                    # Join text parts if multiple
                    response_text = "".join(
                        part.text
                        for part in candidate.content.parts
                        if hasattr(part, "text")
                    )

            if not response_text:
                logger.warning(
                    f"Gemini response content is empty for model {model_name}."
                )
                return "Error: Received empty content from Gemini."

            return response_text

        except GoogleAPIErrors.DeadlineExceeded:
            logger.error(
                f"Gemini API call timed out after {timeout}s for model {model_name}"
            )
            return f"Error: Gemini API call timed out ({timeout}s)."
        except GoogleAPIErrors.GoogleAPIError as e:
            logger.error(f"Gemini API error for model {model_name}: {e}", exc_info=True)
            return f"Error: Gemini API Error - {e}"
        except asyncio.TimeoutError:
            logger.error(
                f"Gemini async call timed out after {timeout}s for model {model_name}"
            )
            return f"Error: Gemini operation timed out ({timeout}s)."
        except Exception as e:
            error_msg = f"Error analyzing with Gemini model {model_name}: {str(e)}"
            logger.error(error_msg, exc_info=True)
            return error_msg

    # Kept for compatibility with ModelRegistry if needed, but static data is primary
    def get_available_models(self) -> List[Dict]:
        """Get list of known Gemini models this integration supports"""
        # Rely on the static ModelRegistry data for the primary list
        # This method might be removed or updated to query actual live models if needed
        return []  # Let ModelRegistry handle the model list


