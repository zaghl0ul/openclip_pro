    def list_providers(self) -> List[str]:
        """List all configured AI providers."""
        return sorted(list(self.KNOWN_MODELS.keys()))

    def list_models_for_provider(self, provider: str) -> List[str]:
        """List model names available for a specific provider based on static data."""
        # Note: For dynamic providers like Ollama, this only lists *known* types.
        # A live check (via AIClientFactory) is needed to see *installed* Ollama models.
        provider = provider.capitalize()  # Match internal key format
        return sorted(list(self.KNOWN_MODELS.get(provider, {}).keys()))

    def get_model_info(self, provider: str, model_name: str) -> Optional[Dict]:
        """Get detailed information about a specific model."""
        provider = provider.capitalize()
        return self.KNOWN_MODELS.get(provider, {}).get(model_name)

    def list_providers_with_models(self) -> Dict[str, List[str]]:
        """Return a dictionary of providers and their respective model names."""
        return {p: self.list_models_for_provider(p) for p in self.list_providers()}

    def list_vision_models(self) -> List[Dict]:
        """List all models that support image input."""
        vision_models = []
        for provider, models in self.KNOWN_MODELS.items():
            for name, info in models.items():
                if "image" in info.get("capabilities", []):
                    vision_models.append({"provider": provider, "model": name, **info})
        return vision_models

    def list_free_models(self) -> List[Dict]:
        """List models that do not require an API key (e.g., local Ollama)."""
        free_models = []
        for provider, models in self.KNOWN_MODELS.items():
            for name, info in models.items():
                # Explicitly check requires_api_key and not just its absence
                if info.get("requires_api_key", True) is False:
                    free_models.append({"provider": provider, "model": name, **info})
        return free_models


##############################
# AI Client Factory
##############################
class AIClientFactory:
    """Factory for creating and managing AI client instances."""

    def __init__(self, key_manager: APIKeyManager, model_registry: ModelRegistry):
        self.key_manager = key_manager
        self.model_registry = model_registry
        self.clients = {}  # Cache initialized async clients

    async def get_client(self, provider: str, model_name: str = None) -> Any:
        """Get or create an AI client for the specified provider."""
        provider_lower = provider.lower()
        client_key = provider_lower  # Cache client instance per provider name

        # Reuse cached client if available
        if client_key in self.clients:
            # Consider adding a check here if the API key for this provider has changed,
            # and re-initialize the client if necessary.
            return self.clients[client_key]

        # Determine if API key is needed for this provider/model combination
        # Default to requiring key unless info says otherwise
        requires_api_key = True
        if model_name:
            model_info = self.model_registry.get_model_info(provider, model_name)
            if model_info:
                requires_api_key = model_info.get("requires_api_key", True)
        elif provider_lower == "ollama":  # Ollama generally doesn't need a key
            requires_api_key = False
            # For Ollama, also check if it's running. This adds latency.
            # It might be better to handle Ollama connection errors on first use.

        api_key = None
        if requires_api_key:
            api_key = self.key_manager.get_key(provider_lower)
            if not api_key:
                # Explicitly raise an error if a key is required but not found
                raise ValueError(
                    f"API key required but not found for provider: {provider}"
                )

        # Initialize client based on provider
        client = None
        try:
            if provider_lower == "openai" and AsyncOpenAI:
                # AsyncOpenAI is the preferred client for async operations
                client = AsyncOpenAI(api_key=api_key, timeout=DEFAULT_API_TIMEOUT)
            elif provider_lower == "anthropic" and anthropic:
                # AsyncAnthropic client
                client = anthropic.AsyncAnthropic(
                    api_key=api_key, timeout=DEFAULT_API_TIMEOUT
                )
            elif provider_lower == "google" and genai:
                # Use our GeminiIntegration wrapper which handles genai.configure
                # Pass the key here for the wrapper to configure the global genai object
                client = GeminiIntegration(api_key=api_key)
                if not client.initialized:
                    # GeminiIntegration logs its own failure, but we raise here to stop client creation
                    raise ConnectionError(
                        f"Failed to initialize Google Gemini client for provider: {provider}"
                    )
            elif provider_lower == "ollama" and ollama:
                # For Ollama, initialize client and optionally test connection
                # Using AsyncClient if available
                try:
                    if hasattr(ollama, "AsyncClient"):
                        client = ollama.AsyncClient(timeout=DEFAULT_API_TIMEOUT)
                        # Optional: await client.list() # Test connection - can add latency
                    else:
                        # Fallback to sync client, will need executor for calls later
                        client = ollama.Client(timeout=DEFAULT_API_TIMEOUT)
                        # client.list() # Test connection - blocks
                        logger.warning(
                            "Using sync Ollama client. Calls will run in executor."
                        )

                except Exception as ollama_err:
                    logger.error(
                        f"Ollama connection error: {ollama_err}", exc_info=True
                    )
                    raise ConnectionError(
                        f"Could not connect to Ollama server. Ensure it's running. Error: {ollama_err}"
                    )

            # Add other providers here (e.g., HuggingFace Inference API requires aiohttp or requests)
            # elif provider_lower == "huggingface":
            #     # Example: create an aiohttp session for HuggingFace Inference API calls
            #     # Need to manage this session lifecycle (close it later)
            #     if 'hf_client_session' not in self.clients: # Use a specific cache key
            #          self.clients['hf_client_session'] = aiohttp.ClientSession(
            #              headers={'Authorization': f'Bearer {api_key}'} if api_key else {}
            #          )
            #     client = self.clients['hf_client_session']

            else:
                # If provider name doesn't match known ones, check if the import failed
                if provider_lower == "anthropic" and not anthropic:
                    raise ImportError("Anthropic package not installed.")
                if provider_lower == "google" and not genai:
                    raise ImportError("google-generativeai package not installed.")
                if provider_lower == "ollama" and not ollama:
                    raise ImportError("ollama package not installed.")
                # If import succeeded but provider is unknown
                raise ValueError(f"Unsupported or uninitialized provider: {provider}")

            # Cache the successfully created client instance
            self.clients[client_key] = client
            logger.info(f"Initialized AI client for provider: {provider}")
            return client

        except (ValueError, ConnectionError, ImportError) as e:
            # Re-raise expected errors, AIModelManager will catch them
            raise e
        except Exception as e:
            # Catch any other unexpected errors during client initialization
            logger.error(
                f"Unexpected error during client initialization for provider {provider}: {e}",
                exc_info=True,
            )
            raise RuntimeError(
                f"Failed to initialize client for {provider}: {e}"
            )  # Raise a generic RuntimeError

    async def close_all(self):
        """Close open client sessions (e.g., aiohttp)."""
        logger.info("Closing all AI client sessions...")
        for client_key, client in self.clients.items():
            try:
                # Add specific closing logic for clients that need it
                if isinstance(client, aiohttp.ClientSession):
                    if not client.closed:
                        await client.close()
                        logger.info(f"Closed aiohttp client session for {client_key}")
                # Add other cleanup logic if needed (e.g., some libraries might have close methods)
                # Example: if hasattr(client, 'close'): await client.close()
            except Exception as e:
                logger.error(f"Error closing client {client_key}: {e}", exc_info=True)
        self.clients = {}  # Clear the cache


##############################
# AI Model Manager
##############################
class AIModelManager:
    """Manages AI model interactions, provides unified async interface."""

    def __init__(self, key_manager: APIKeyManager, model_registry: ModelRegistry):
        self.key_manager = key_manager
        self.model_registry = model_registry
        self.client_factory = AIClientFactory(key_manager, model_registry)

    async def analyze_with_model(
        self,
        provider: str,
        model_name: str,
        prompt: str,
        images: Optional[List[str]] = None,  # List of base64 image strings
        temperature: float = DEFAULT_TEMPERATURE,
        max_tokens: int = DEFAULT_MAX_TOKENS,
        timeout: int = DEFAULT_API_TIMEOUT,
        format_type: str = "json",
    ) -> str:
        """
        Run analysis with a specific AI model, handling different providers.

        Args:
            provider: The AI provider name (e.g., "OpenAI", "Google").
            model_name: The specific model name (e.g., "gpt-4o", "gemini-1.5-flash-latest").
            prompt: The text prompt for the AI.
            images: Optional list of base64 encoded image strings for multimodal models.
            temperature: Controls randomness (0.0 to 2.0).
            max_tokens: Maximum number of output tokens.
            timeout: Request timeout in seconds.
            format_type: Requested output format ("text" or "json").

        Returns:
            The AI's response text, or an error string starting with "Error:".
        """
        provider_lower = provider.lower()
        # Get model info from the registry
        model_info = self.model_registry.get_model_info(provider_lower, model_name)
        if not model_info:
            return f"Error: Model '{model_name}' not found or not supported for provider '{provider}'."

        # Check if the model supports image input if images are provided
        if images and "image" not in model_info.get("capabilities", []):
            logger.warning(
                f"Model {provider}:{model_name} does not support images, but images were provided. Ignoring images."
            )
            images = None
        # If images are required by the prompt but not provided, this will likely fail later.

        # Get client instance using the factory
        try:
            client = await self.client_factory.get_client(provider_lower, model_name)
            if (
                client is None and provider_lower != "ollama"
            ):  # Ollama client can be sync, checked later
                # get_client should raise errors, but this is a safety check
                return f"Error: Could not obtain client for provider {provider}. Check API keys and dependencies."

        except (ValueError, ConnectionError, ImportError) as e:
            # Catch expected errors from client factory and return them to caller
            return f"Error: Client initialization failed - {e}"
        except Exception as e:
            # Catch unexpected errors from client factory
            logger.error(
                f"Unexpected error getting client for {provider}/{model_name}: {e}",
                exc_info=True,
            )
            return f"Error: Failed to get AI client ({type(e).__name__})."

        # Handle JSON format request in prompt if needed (though some clients support native JSON mode)
        # For models/providers without explicit JSON mode, add instruction to prompt
        if (
            format_type == "json"
            and model_info.get("capabilities", {}).get("json", False) is False
        ):
            prompt = self._format_json_prompt(prompt)

        # --- Call Provider-Specific Methods ---
        try:
            if provider_lower == "openai" and isinstance(client, AsyncOpenAI):
                return await self._analyze_with_openai(
                    client,
                    model_name,
                    prompt,
                    images,
                    temperature,
                    max_tokens,
                    timeout,
                    format_type,
                )
            elif (
                provider_lower == "anthropic"
                and anthropic
                and isinstance(client, anthropic.AsyncAnthropic)
            ):
                return await self._analyze_with_anthropic(
                    client, model_name, prompt, images, temperature, max_tokens, timeout
                )
            elif (
                provider_lower == "google"
                and genai
                and isinstance(client, GeminiIntegration)
            ):
                # Our GeminiIntegration wrapper is async
                return await client.analyze_with_gemini(
                    model_name,
                    prompt,
                    images,
                    temperature,
                    max_tokens,
                    timeout,
                    format_type,
                )
            elif provider_lower == "ollama" and ollama:
                # Ollama client can be sync or async
                return await self._analyze_with_ollama(
                    client, model_name, prompt, images, temperature, timeout
                )
            # Add other providers here
            else:
                # This case should be caught by get_client or import checks, but here as a fallback
                return f"Error: Provider '{provider}' is not supported, its client failed to initialize, or dependencies are missing."

        except (
            APIError,
            OpenAITimeout,
            AnthropicAPIError,
            AnthropicTimeout,
            GoogleAPIErrors.GoogleAPIError,
            GoogleAPIErrors.DeadlineExceeded,
            asyncio.TimeoutError,
            ConnectionError,  # Include ConnectionError for Ollama sync in executor
        ) as e:
            # Catch known API/network errors from provider methods
            logger.error(
                f"API call error with {provider}/{model_name}: {type(e).__name__} - {e}"
            )
            return f"Error: API call failed ({type(e).__name__}). Details: {e}"
        except Exception as e:
            # Catch any other unexpected errors during the API call or response processing
            logger.error(
                f"Unexpected error during analysis with {provider}/{model_name}: {e}",
                exc_info=True,
            )
            return f"Error: An unexpected error occurred during analysis ({type(e).__name__}). Check logs."

    def _format_json_prompt(self, prompt: str) -> str:
        """Append JSON formatting instructions to the prompt if not already present."""
        # Check if prompt already contains JSON specific keywords
        prompt_lower = prompt.lower()
        if "json" in prompt_lower[-20:] or "json object" in prompt_lower:
            return prompt  # Don't add if already requested JSON explicitly

        json_instruction = "Respond ONLY with a valid JSON object."
        # Add instruction clearly, perhaps with structure example if possible
        # For this app, the prompt construction in create_project_page already adds this.
        # This method might be redundant if all prompts are constructed to request JSON.
        # Keeping it as a general safeguard.
        if json_instruction not in prompt:
            prompt = f"{prompt}\n\n{json_instruction}"
            logger.debug("Added JSON formatting instruction to prompt.")
        return prompt

    # --- Provider-Specific Implementation Details ---
    # These methods handle the specifics of calling each provider's client

    async def _analyze_with_openai(
        self,
        client: AsyncOpenAI,
        model_name: str,
        prompt: str,
        images: Optional[List[str]],
        temperature: float,
        max_tokens: int,
        timeout: int,
        format_type: str,
    ) -> str:
        """Call OpenAI Chat Completions API."""
        content = [{"type": "text", "text": prompt}]
        if images:
            for img_b64 in images:
                # OpenAI Vision requires data URLs
                content.append(
                    {
                        "type": "image_url",
                        "image_url": {"url": f"data:image/jpeg;base64,{img_b64}"},
                    }
                )

        request_params = {
            "model": model_name,
            "messages": [{"role": "user", "content": content}],
            "temperature": temperature,
            "max_tokens": max_tokens,
            "timeout": timeout,  # Timeout parameter is supported by AsyncOpenAI
        }
        # Use native JSON mode if supported by the model and requested
        model_info = self.model_registry.get_model_info("openai", model_name)
        if (
            format_type == "json"
            and model_info
            and model_info.get("capabilities", {}).get("json", False)
        ):
            request_params["response_format"] = {"type": "json_object"}
            logger.debug(f"Using native OpenAI JSON mode for model {model_name}.")

        response = await client.chat.completions.create(**request_params)
        result = response.choices[0].message.content

        if result is None:
            logger.warning(f"OpenAI response content is None for model {model_name}.")
            return "Error: Received empty response content from OpenAI."

        return result

    async def _analyze_with_anthropic(
        self,
        client: anthropic.AsyncAnthropic,
        model_name: str,
        prompt: str,
        images: Optional[List[str]],
        temperature: float,
        max_tokens: int,
        timeout: int,
    ) -> str:
        """Call Anthropic Messages API."""
        # Anthropic structure for multimodal content
        content_parts = []
        if images:
            for img_b64 in images:
                content_parts.append(
                    {
                        "type": "image",
                        "source": {
                            "type": "base64",
                            "media_type": "image/jpeg",
                            "data": img_b64,
                        },
                    }
                )
        # Text part goes last
        content_parts.append({"type": "text", "text": prompt})

        # Note: Timeout is set on client initialization, not per-call parameter usually
        response = await client.messages.create(
            model=model_name,
            max_tokens=max_tokens,
            temperature=temperature,
            messages=[{"role": "user", "content": content_parts}],
        )

        # Check for empty content blocks in the response
        if not response.content:
            logger.warning(
                f"Anthropic response has empty content for model {model_name}."
            )
            return "Error: Received empty content block from Anthropic."

        # Anthropic content is a list of blocks, get the first text block
        response_text = "".join(
            block.text for block in response.content if block.type == "text"
        )

        if not response_text:
            logger.warning(f"Anthropic response text is empty for model {model_name}.")
            return "Error: Received empty text content from Anthropic response."

        return response_text

    async def _analyze_with_ollama(
        self,
        client: Union[ollama.AsyncClient, ollama.Client],
        model_name: str,
        prompt: str,
        images: Optional[List[str]],
        temperature: float,
        timeout: int,
    ) -> str:
        """Call Ollama Generate API."""
        payload = {
            "model": model_name,
            "prompt": prompt,
            "stream": False,  # We want the full response at once
            "options": {"temperature": temperature},
        }
        if images:
            # Ollama expects a list of base64 strings directly in the 'images' field
            payload["images"] = images

        try:
            # Use async client directly if it was initialized
            if isinstance(client, ollama.AsyncClient):
                response = await asyncio.wait_for(
                    client.generate(**payload), timeout=timeout
                )
            # Otherwise, run sync client method in a thread pool executor
            elif isinstance(client, ollama.Client):
                loop = asyncio.get_running_loop()
                # Wrap the blocking sync call in run_in_executor
                response = await asyncio.wait_for(
                    loop.run_in_executor(None, lambda: client.generate(**payload)),
                    timeout=timeout,
                )
            else:
                raise ValueError(f"Unsupported Ollama client type: {type(client)}")

            # Extract response text from the Ollama response dictionary
            if isinstance(response, dict):
                result = response.get("response", "")
                if not result:
                    logger.warning(
                        f"Ollama response missing 'response' field or it's empty for model {model_name}. Response keys: {response.keys()}"
                    )
                    return "Error: Received empty response from Ollama."
                return result
            else:
                logger.warning(
                    f"Unexpected response type from Ollama for model {model_name}: {type(response)}. Expected dict."
                )
                return "Error: Unexpected response format from Ollama."

        # Specific exception for when Ollama model is not found
        except ollama.ResponseError as e:
            if "model '" in str(e) and "' not found" in str(e):
                logger.error(f"Ollama model '{model_name}' not found locally: {e}")
                return f"Error: Ollama model '{model_name}' not found. Please pull the model using `ollama pull {model_name}`."
            else:
                logger.error(
                    f"Ollama ResponseError for model {model_name}: {e}", exc_info=True
                )
                return f"Error: Ollama API responded with an error - {e}"
        except asyncio.TimeoutError:
            logger.error(
                f"Ollama operation timed out after {timeout}s for model {model_name}"
            )
            return f"Error: Ollama operation timed out ({timeout}s)."
        except (
            ConnectionError
        ) as e:  # Catch connection errors from sync executor fallback
            logger.error(
                f"Ollama connection error during sync call: {e}", exc_info=True
            )
            return f"Error: Ollama connection failed - {e}"
        except Exception as e:
            error_msg = f"Error analyzing with Ollama model {model_name}: {str(e)}"
            logger.error(error_msg, exc_info=True)
            return error_msg

    async def close(self):
        """Close all clients and connections managed by the factory."""
        await self.client_factory.close_all()


##############################
# Main AI Analysis Module
##############################
class AIAnalysisModule:
    """Main AI Analysis Module for managing AI-related operations."""

    def __init__(self):
        self.key_manager = APIKeyManager()
        self.model_registry = ModelRegistry()
        self.model_manager = AIModelManager(self.key_manager, self.model_registry)
        logger.info("AIAnalysisModule initialized.")

    # Methods for AI tasks, using the model_manager

    # analyze_text and analyze_image are covered by analyze_with_model depending on 'images' parameter

    # @st.cache_data(ttl=3600) # Cache results for an hour? Be cautious with caching mutable results
    # Caching might interfere with the AI Board's interactive updates.
    # Better to manage caching within the AI Board UI itself (using session state).
    async def run_ai_board_analysis_for_clip(
        self, clip: Dict, project: Dict, board_config: Dict
    ) -> Dict:
        """
        Runs the AI Board analysis for a single clip using configured models and tasks.

        Args:
            clip: The clip dictionary.
            project: The parent project dictionary (for context like video path).
            board_config: Dictionary with 'board_members', 'chairperson', 'board_tasks'.

        Returns:
            Updated clip dictionary including AI analysis results or error messages.
        """
        if not board_config.get("board_enabled") or not board_config.get(
            "board_members"
        ):
            logger.warning(
                "AI Board analysis called but board is disabled or has no members."
            )
            return clip  # Return original clip if board is off

        members = board_config["board_members"]
        tasks = board_config.get("board_tasks", [])
        chairperson = board_config.get("chairperson")

        logger.info(
            f"Running AI Board analysis for clip {clip['id']} with {len(members)} members and {len(tasks)} tasks."
        )

        # --- Prepare input for AI models ---
        # Need a frame representing the clip. Use the thumbnail path.
        thumbnail_path = clip.get("thumbnail")
        base64_image = None
        if thumbnail_path and os.path.exists(thumbnail_path):
            try:
                # Use optimize_and_encode_image from media_utils
                from media_utils import optimize_and_encode_image

                # Use reasonable quality/resolution for AI analysis frames
                project_settings = project.get(
                    "settings", {}
                )  # Get settings used during project creation
                img_quality = int(project_settings.get("compression_quality", 85))
                max_res = int(project_settings.get("max_resolution", 720))
                base64_image = optimize_and_encode_image(
                    thumbnail_path, quality=img_quality, max_resolution=max_res
                )
                if not base64_image:
                    logger.warning(
                        f"Failed to encode thumbnail {thumbnail_path} for AI."
                    )
            except Exception as e:
                logger.error(
                    f"Error preparing image for AI board analysis: {e}", exc_info=True
                )
                base64_image = None
        else:
            logger.warning(
                f"Thumbnail not found for clip {clip['id']}. AI Vision analysis may not work."
            )

        # Context prompt for the board
        context_prompt = (
            f"Analyze this video clip segment (approx time {clip.get('start', 0):.1f}s to {clip.get('end', 0):.1f}s). "
            f"Its initial analysis results were: Score {clip.get('score', 0)}, Tag '{clip.get('tag', 'N/A')}', Category '{clip.get('category', 'N/A')}', Quip: '{clip.get('quip', 'N/A')}'. "
            "Consider the visual content (if provided), the context implied by the scene, and the segment's timing within the original video. "
            "Provide insights and metrics relevant to the assigned task. Be concise and provide actionable points."
        )

        # --- Define Tasks and Prompts for Board Members ---
        # Map task names to specific prompts and expected outputs
        task_prompts = {
            "viral_analysis": {
                "prompt": context_prompt
                + "\n\nTask: Analyze this clip for its potential virality on social media (e.g., TikTok, Instagram Reels, YouTube Shorts). Provide a 'viral_score' (0-100) and 'viral_tags' (list of keywords/hashtags) and 'viral_recommendations' (brief tips for sharing).",
                "output_keys": ["viral_score", "viral_tags", "viral_recommendations"],
                "score_key": "viral_score",  # Key to use for the score synthesis
            },
            "monetization_analysis": {
                "prompt": context_prompt
                + "\n\nTask: Analyze this clip for its potential monetization or revenue generation (e.g., suitability for ads, sponsored content, product placement). Provide a 'monetization_score' (0-100) and 'monetization_tags' (relevant keywords) and 'monetization_recommendations' (brief tips for monetization).",
                "output_keys": [
                    "monetization_score",
                    "monetization_tags",
                    "monetization_recommendations",
                ],
                "score_key": "monetization_score",
            },
            # Add other potential tasks
            # "hook_analysis": { ... }
        }

        # Filter tasks to run based on board_config["board_tasks"]
        tasks_to_run = {
            task: task_prompts[task] for task in tasks if task in task_prompts
        }

        if not tasks_to_run:
            logger.warning(
                f"No valid tasks configured for AI Board analysis for clip {clip['id']}."
            )
            return clip  # Return original clip if no tasks

        # --- Run Member Analysis Tasks in Parallel ---
        # Use ThreadPoolExecutor to manage concurrent async calls for board members
        # The max_workers for this pool should be configurable, related to max_workers_api maybe?
        # Let's use max_workers_api from project settings.
        max_workers_api = int(project.get("settings", {}).get("max_workers_api", 8))
        member_results = (
            {}
        )  # Store results per member: { "provider:model": {task: result_dict} }

        async def run_member_task(
            member_info: Dict, task_name: str, task_details: Dict
        ):
            """Runs a single task for a single board member asynchronously."""
            provider = member_info["provider"]
            model_name = member_info["model"]
            member_key = f"{provider}:{model_name}"
            prompt = task_details["prompt"]
            # Images are passed only if the model supports vision
            model_info = self.model_registry.get_model_info(provider, model_name)
            use_images = (
                base64_image
                if model_info and "image" in model_info.get("capabilities", [])
                else None
            )

            logger.debug(
                f"Clip {clip['id']} - Member {member_key}: Running task '{task_name}'"
            )

            try:
                # Use AIModelManager to call the model
                response_text = await self.model_manager.analyze_with_model(
                    provider=provider,
                    model_name=model_name,
                    prompt=prompt,
                    images=use_images,
                    temperature=0.7,  # Use a moderate temperature for analysis
                    max_tokens=DEFAULT_MAX_TOKENS,
                    timeout=DEFAULT_API_TIMEOUT,
                    format_type="json",  # Request JSON output for structured tasks
                )

                if response_text.startswith("Error:"):
                    logger.error(
                        f"Clip {clip['id']} - Member {member_key} - Task '{task_name}': API Error - {response_text}"
                    )
                    return {
                        "task": task_name,
                        "status": "error",
                        "error": response_text,
                    }

                # Attempt to parse and validate JSON response
                try:
                    # Find and parse JSON payload
                    json_start = response_text.find("{")
                    json_end = response_text.rfind("}")
                    if json_start != -1 and json_end != -1:
                        clean_response = response_text[json_start : json_end + 1]
                        result_data = json.loads(clean_response)
                        # Basic validation: check if expected keys are present
                        missing_keys = [
                            k
                            for k in task_details["output_keys"]
                            if k not in result_data
                        ]
                        if missing_keys:
                            raise ValueError(
                                f"Missing expected keys: {', '.join(missing_keys)}"
                            )

                        logger.debug(
                            f"Clip {clip['id']} - Member {member_key} - Task '{task_name}': Success"
                        )
                        return {
                            "task": task_name,
                            "status": "success",
                            "result": result_data,
                        }

                    else:
                        raise json.JSONDecodeError(
                            "JSON object markers not found", response_text, 0
                        )

                except (json.JSONDecodeError, ValueError, TypeError) as e:
                    logger.error(
                        f"Clip {clip['id']} - Member {member_key} - Task '{task_name}': JSON/Validation Error - {e}. Raw: '{response_text[:200]}...'"
                    )
                    return {
                        "task": task_name,
                        "status": "error",
                        "error": f"JSON/Validation Error: {e}",
                        "raw_response": response_text,
                    }

            except Exception as e:
                logger.error(
                    f"Clip {clip['id']} - Member {member_key} - Task '{task_name}': Unexpected Error - {e}",
                    exc_info=True,
                )
                return {
                    "task": task_name,
                    "status": "error",
                    "error": f"Unexpected error during task: {e}",
                }

        # Use asyncio to run multiple async member tasks concurrently
        async def gather_member_tasks():
            # Create a list of async tasks for each member and each task type
            tasks_to_gather = []
            for member_info in members:
                for task_name, task_details in tasks_to_run.items():
                    tasks_to_gather.append(
                        run_member_task(member_info, task_name, task_details)
                    )

            # Run tasks concurrently
            # Use a limited number of concurrent API calls if needed, but client factory handles some pooling
            # asyncio.gather runs them all, relying on the underlying async client limits/timeouts
            return await asyncio.gather(*tasks_to_gather)

        # Run the async task gathering in a separate thread if called from sync Streamlit context
        # This requires the ThreadPoolExecutor and asyncio.run pattern again.
        # !!! POTENTIAL ISSUE - See comments in create_project_page.analyze_video_for_clips !!!
        logger.info(
            f"Starting async AI Board tasks for clip {clip['id']} using {max_workers_api} max workers."
        )
        loop = asyncio.new_event_loop()  # Create a new event loop for this thread
        asyncio.set_event_loop(loop)
        try:
            # Use a separate ThreadPoolExecutor for running async calls
            # This is complex and can have performance/stability implications
            with concurrent.futures.ThreadPoolExecutor(
                max_workers=max_workers_api, thread_name_prefix="AIBoardTask"
            ) as executor:
                future = executor.submit(loop.run_until_complete, gather_member_tasks())
                results_list = future.result()  # Wait for all tasks to complete

            # Process results_list to populate member_results dictionary
            for result_item in results_list:
                if result_item and result_item["status"] == "success":
                    # Find which member this result belongs to - this requires correlating the result back
                    # Or modify run_member_task to include member info in the return
                    # Let's modify run_member_task return structure
                    member_key = result_item.get(
                        "member_key"
                    )  # Assuming run_member_task returns this
                    task_name = result_item.get("task")
                    if member_key and task_name:
                        member_results.setdefault(member_key, {})[task_name] = (
                            result_item["result"]
                        )
                    else:
                        logger.warning(
                            f"Received AI Board result without member_key or task name: {result_item}"
                        )
                elif result_item and result_item["status"] == "error":
                    member_key = result_item.get("member_key", "Unknown Member")
                    task_name = result_item.get("task", "Unknown Task")
                    logger.error(
                        f"AI Board task failed: Member={member_key}, Task={task_name}, Error={result_item.get('error')}"
                    )
                    # Store error status if needed for UI
                    member_results.setdefault(member_key, {})[task_name] = {
                        "status": "error",
                        "error": result_item.get("error"),
                    }

        except Exception as e:
            logger.error(
                f"Error executing AI Board tasks for clip {clip['id']} in thread pool: {e}",
                exc_info=True,
            )
            # Indicate overall failure for this clip
            clip["ai_board_error"] = f"Failed to run AI Board tasks: {e}"
            return clip
        finally:
            # Clean up the event loop created in this thread
            loop.close()
            asyncio.set_event_loop(None)  # Clear the event loop for the thread

        logger.info(
            f"AI Board raw results for clip {clip['id']}: {json.dumps(member_results, indent=2)}"
        )

        # --- Synthesize Results (Chairperson) ---
        # This part needs a prompt for the chairperson model and processing its response
        final_clip_updates = (
            {}
        )  # Dictionary to store the synthesized updates for the clip

        if chairperson and member_results:
            chair_provider = chairperson["provider"]
            chair_model = chairperson["model"]
            chair_key = f"{chair_provider}:{chair_model}"
            logger.info(
                f"Clip {clip['id']}: Running synthesis with Chairperson {chair_key}"
            )

            # Prepare input for the chairperson - usually text summarizing member results
            synthesis_prompt = (
                f"Acting as the Chairperson of an AI Board evaluating a video clip (time {clip.get('start', 0):.1f}s to {clip.get('end', 0):.1f}s). "
                "Synthesize the analysis results from different board members provided below. "
                "Your goal is to consolidate scores (if applicable), tags, and recommendations into a single, coherent summary and set of final metrics/recommendations for this clip. "
                "Focus on the most relevant or highest-scoring insights. "
                "Provide a final 'ai_viral_score' (0-100) and 'ai_monetization_score' (0-100) if these tasks were run. "
                "Also provide consolidated 'ai_tags' (list of strings) and 'ai_recommendations' (list of strings).\n\n"
                "Board Member Results (JSON format, ignore formatting errors):\n"
                f"{json.dumps(member_results, indent=2)}\n\n"
                "Synthesized Output (JSON format ONLY):"
                "```json\n{\n"  # Suggest JSON structure
                '  "ai_viral_score": <integer 0-100>,\n'
                '  "ai_monetization_score": <integer 0-100>,\n'
                '  "ai_tags": ["tag1", "tag2", ...],\n'
                '  "ai_recommendations": ["recommendation1", "recommendation2", ...],\n'
                '  "chairperson_summary": "Brief summary of key findings."\n'
                "}\n```\n"
                "Provide only the JSON object."
            )

            # Chairperson typically needs text input only, unless it's a multimodal model
            chair_model_info = self.model_registry.get_model_info(
                chair_provider, chair_model
            )
            chair_use_images = (
                base64_image
                if chair_model_info
                and "image" in chair_model_info.get("capabilities", [])
                else None
            )  # Pass image if chair is multimodal

            # Call the chairperson model - this is another async call
            # Again, needs to run in an event loop, potentially via asyncio.run in an executor if this is called from sync Streamlit
            # Let's reuse the same thread pool approach
            logger.debug(
                f"Running Chairperson ({chair_key}) synthesis for clip {clip['id']}."
            )

            async def run_chairperson_synthesis():
                return await self.model_manager.analyze_with_model(
                    provider=chair_provider,
                    model_name=chair_model,
                    prompt=synthesis_prompt,
                    images=chair_use_images,
                    temperature=0.3,  # Lower temperature for less creative synthesis
                    max_tokens=DEFAULT_MAX_TOKENS,
                    timeout=DEFAULT_API_TIMEOUT,
                    format_type="json",  # Request JSON output
                )

            loop = asyncio.new_event_loop()
            asyncio.set_event_loop(loop)
            try:
                with concurrent.futures.ThreadPoolExecutor(
                    max_workers=1, thread_name_prefix="AIBoardChair"
                ) as executor:  # Use 1 worker for chair synthesis
                    future = executor.submit(
                        loop.run_until_complete, run_chairperson_synthesis()
                    )
                    synthesis_response_text = future.result()

                logger.debug(
                    f"Chairperson response for clip {clip['id']}: {synthesis_response_text}"
                )

                # Process Chairperson's JSON response
                if synthesis_response_text.startswith("Error:"):
                    logger.error(
                        f"Clip {clip['id']} - Chairperson {chair_key}: API Error - {synthesis_response_text}"
                    )
                    final_clip_updates["ai_board_synthesis_error"] = (
                        f"Chairperson API Error: {synthesis_response_text}"
                    )
                else:
                    try:
                        # Attempt to parse JSON
                        json_start = synthesis_response_text.find("{")
                        json_end = synthesis_response_text.rfind("}")
                        if json_start != -1 and json_end != -1:
                            clean_response = synthesis_response_text[
                                json_start : json_end + 1
                            ]
                            synth_result = json.loads(clean_response)

                            # Validate and extract desired fields
                            final_clip_updates["ai_viral_score"] = int(
                                synth_result.get(
                                    "ai_viral_score", clip.get("ai_viral_score", 0)
                                )
                            )  # Keep existing if not provided
                            final_clip_updates["ai_monetization_score"] = int(
                                synth_result.get(
                                    "ai_monetization_score",
                                    clip.get("ai_monetization_score", 0),
                                )
                            )
                            final_clip_updates["ai_tags"] = list(
                                set(
                                    clip.get("ai_tags", [])
                                    + synth_result.get("ai_tags", [])
                                )
                            )  # Combine and deduplicate tags
                            final_clip_updates["ai_recommendations"] = list(
                                set(
                                    clip.get("ai_recommendations", [])
                                    + synth_result.get("ai_recommendations", [])
                                )
                            )  # Combine and deduplicate recommendations
                            final_clip_updates["ai_board_summary"] = synth_result.get(
                                "chairperson_summary", "No summary provided."
                            )

                            # Ensure scores are within 0-100
                            final_clip_updates["ai_viral_score"] = max(
                                0, min(100, final_clip_updates["ai_viral_score"])
                            )
                            final_clip_updates["ai_monetization_score"] = max(
                                0, min(100, final_clip_updates["ai_monetization_score"])
                            )

                            logger.info(
                                f"Clip {clip['id']}: Chairperson synthesis successful."
                            )

                        else:
                            raise json.JSONDecodeError(
                                "JSON object markers not found",
                                synthesis_response_text,
                                0,
                            )

                    except (json.JSONDecodeError, ValueError, TypeError) as e:
                        logger.error(
                            f"Clip {clip['id']} - Chairperson {chair_key}: JSON/Validation Error - {e}. Raw: '{synthesis_response_text[:200]}...'"
                        )
                        final_clip_updates["ai_board_synthesis_error"] = (
                            f"Chairperson JSON/Validation Error: {e}"
                        )
                    except Exception as e:
                        logger.error(
                            f"Clip {clip['id']} - Chairperson {chair_key}: Unexpected Error during synthesis processing - {e}",
                            exc_info=True,
                        )
                        final_clip_updates["ai_board_synthesis_error"] = (
                            f"Chairperson processing error: {e}"
                        )

            except Exception as e:
                logger.error(
                    f"Error executing Chairperson synthesis for clip {clip['id']} in thread pool: {e}",
                    exc_info=True,
                )
                final_clip_updates["ai_board_synthesis_error"] = (
                    f"Failed to run Chairperson synthesis: {e}"
                )
            finally:
                loop.close()
                asyncio.set_event_loop(None)

        # --- Combine all results into the clip data ---
        # Add raw member results to clip data (optional, for debugging/details view)
        clip["ai_board_raw_results"] = member_results
        clip.update(final_clip_updates)  # Update the clip dict with synthesized results

        logger.debug(
            f"Clip {clip['id']} AI Board analysis complete. Updates: {final_clip_updates.keys()}"
        )

        # Return the updated clip dictionary
        return clip

    def display_ai_board_ui(self, project: Dict, board_config: Dict):
        """
        Streamlit UI function to display the AI Board tab content.
        Handles triggering analysis and showing results.
        """
        st.subheader("🧠 AI Board of Directors Analysis")
        st.caption(
            "Evaluate clips using multiple AI models ('Board Members') and synthesize their findings with a 'Chairperson' model."
        )

        clips = project.get("clips", [])
        if not clips:
            st.info("This project has no clips to analyze with the AI Board.")
            return

        board_enabled = board_config.get("board_enabled", False)
        members = board_config.get("board_members", [])
        tasks = board_config.get("board_tasks", [])
        chairperson = board_config.get("chairperson")

        if not board_enabled:
            st.info(
                "AI Board is currently disabled. Enable and configure it in the sidebar 'AI Model Configuration' section."
            )
            return

        if not members:
            st.warning(
                "No AI Board members selected. Configure them in the sidebar 'AI Model Configuration' section."
            )
            return

        if not tasks:
            st.warning(
                "No AI Board tasks selected. Configure them in the sidebar 'AI Model Configuration' section."
            )
            return

        if not chairperson:
            st.warning(
                "No AI Board 'Chairperson' model selected. Select one from your board members in the sidebar 'Advanced Board Settings'. Synthesis results may be unavailable."
            )

        st.markdown("---")
        st.markdown("#### AI Board Configuration for this run:")
        st.write(
            f"**Members:** {', '.join([f'{m["provider"]}:{m["model"]}' for m in members])}"
        )
        st.write(f"**Tasks:** {', '.join(tasks)}")
        st.write(
            f"**Chairperson:** {f'{chairperson["provider"]}:{chairperson["model"]}' if chairperson else 'None Selected'}"
        )
        st.markdown("---")

        # Button to trigger analysis for all clips
        # Use a unique key based on project ID
        analyze_all_button_key = f"run_ai_board_all_{project['id']}"
        if st.button(
            "🚀 Run AI Board Analysis on All Clips",
            type="primary",
            use_container_width=True,
            key=analyze_all_button_key,
        ):
            # Clear previous board analysis results cache for this project
            # st.session_state.clip_ai_analysis = {} # Maybe clear on project change, not every button click?
            # Clear results only for THIS project ID
            st.session_state.clip_ai_analysis[project["id"]] = {}
            logger.info(
                f"Starting AI Board analysis for all clips ({len(clips)}) in project {project['id']}."
            )

            # Use a progress bar for the overall process
            progress_bar = st.progress(0.0, text="Starting AI Board analysis...")
            status_text = st.empty()

            # Run analysis clip by clip
            updated_clips = []
            for i, clip in enumerate(clips):
                status_text.text(
                    f"Analyzing clip {i+1}/{len(clips)}: {clip.get('tag', '...')}"
                )
                progress = (i + 1) / len(clips)
                progress_bar.progress(
                    progress, text=f"Analyzing clip {i+1}/{len(clips)}..."
                )

                # Run analysis for this clip (this is an async method)
                # Needs to be run using asyncio.run in a separate thread because this is a sync Streamlit context
                try:
                    loop = asyncio.new_event_loop()
                    asyncio.set_event_loop(loop)
                    # Use a ThreadPoolExecutor to run the async method
                    with concurrent.futures.ThreadPoolExecutor(
                        max_workers=1, thread_name_prefix="AIClipAnalyze"
                    ) as executor:  # Only need one thread for sequential clip analysis
                        future = executor.submit(
                            loop.run_until_complete,
                            self.run_ai_board_analysis_for_clip(
                                clip.copy(), project, board_config
                            ),
                        )  # Pass a copy of the clip
                        updated_clip = future.result()  # Wait for the result
                    loop.close()
                    asyncio.set_event_loop(None)

                    updated_clips.append(updated_clip)

                    # Save updated clip data to database immediately
                    # This prevents losing results if the app crashes during analysis
                    if update_clip_data(updated_clip["id"], updated_clip):
                        logger.debug(
                            f"Saved AI Board results for clip {updated_clip['id']} to DB."
                        )
                    else:
                        logger.error(
                            f"Failed to save AI Board results for clip {updated_clip['id']} to DB."
                        )

                except Exception as e:
                    logger.error(
                        f"Error running AI Board analysis for clip {clip['id']}: {e}",
                        exc_info=True,
                    )
                    status_text.error(f"Error analyzing clip {i+1}: {e}")
                    # Append original clip or clip with error flag if analysis failed
                    clip["ai_board_error"] = f"Analysis Failed: {e}"
                    updated_clips.append(
                        clip
                    )  # Keep the original clip or add error info

            # Analysis complete
            status_text.success("AI Board analysis complete for all clips.")
            progress_bar.progress(1.0, text="Analysis Complete!")
            time.sleep(1)
            progress_bar.empty()
            # The project data in the UI is now potentially outdated.
            # Force a rerun to reload the project with updated clip data from the DB.
            st.rerun()

        # --- Display Results per Clip ---
        st.markdown("#### Results per Clip:")

        # Filter/sort clips for display (optional, could reuse clips tab filters)
        # For simplicity, display all clips here, possibly grouped or expandable.
        # Let's use expanders for each clip's AI Board results.

        # Sort clips by initial score for consistent display order
        display_clips = sorted(clips, key=lambda c: c.get("score", 0), reverse=True)

        if not display_clips:
            st.info("No clips to display results for.")
            return

        # Cache the expanded state of clip results expanders in session state
        if f"ai_board_expander_states_{project['id']}" not in st.session_state:
            st.session_state[f"ai_board_expander_states_{project['id']}"] = {}

        for clip in display_clips:
            clip_id = clip["id"]
            # Determine if AI Board analysis has been run for this specific clip
            # We can tell by checking if specific keys like 'ai_viral_score' are present (and not None)
            has_ai_results = (
                clip.get("ai_viral_score", None) is not None
                or clip.get("ai_monetization_score", None) is not None
            )

            expander_label = f"Clip {clip.get('start', 0):.1f}s - {clip.get('end', 0):.1f}s: {clip.get('tag', 'No Tag')}"
            if has_ai_results:
                # Show synthesized scores in the expander label
                viral_score = clip.get("ai_viral_score", "N/A")
                monetize_score = clip.get("ai_monetization_score", "N/A")
                expander_label += f" (AI V:{viral_score}, M:{monetize_score})"
            else:
                expander_label += " (Analysis Not Run)"

            # Manage expander state using session state
            is_expanded = st.session_state[
                f"ai_board_expander_states_{project['id']}"
            ].get(clip_id, False)

            with st.expander(
                expander_label, expanded=is_expanded, key=f"ai_board_expander_{clip_id}"
            ):
                # Update session state when expander state changes
                st.session_state[f"ai_board_expander_states_{project['id']}"][
                    clip_id
                ] = st._get_session_state()[f"ai_board_expander_{clip_id}"][
                    "expanded"
                ]  # Access Streamlit's internal state

                # Display core clip details first
                _display_clip_details(clip)  # Reuse the helper

                # Show AI Board results if available
                if has_ai_results:
                    st.markdown("##### AI Board Synthesized Results:")
                    ai_viral = clip.get("ai_viral_score")
                    ai_monetize = clip.get("ai_monetization_score")

                    ai_cols = st.columns(2)
                    if ai_viral is not None:
                        ai_cols[0].metric("AI Viral Score", ai_viral)
                    if ai_monetize is not None:
                        ai_cols[1].metric("AI Monetization Score", ai_monetize)

                    ai_tags = clip.get("ai_tags", [])
                    if ai_tags:
                        st.markdown("**Consolidated AI Tags:**")
                        tag_html = " ".join(
                            f"<span style='display:inline-block; background-color:#444; color: #eee; padding: 1px 5px; border-radius:10px; margin-right:3px; margin-bottom:3px; font-size:0.8em;'>{tag}</span>"
                            for tag in ai_tags
                        )
                        st.markdown(tag_html, unsafe_allow_html=True)

                    ai_recs = clip.get("ai_recommendations", [])
                    if ai_recs:
                        st.markdown("**Consolidated AI Recommendations:**")
                        for rec in ai_recs:
                            st.markdown(f"- {rec}")

                    ai_board_summary = clip.get("ai_board_summary")
                    if ai_board_summary:
                        st.markdown("**Chairperson Summary:**")
                        st.markdown(f"> {ai_board_summary}")

                    # Show raw results from members (optional, expander?)
                    raw_results = clip.get("ai_board_raw_results")
                    if raw_results:
                        with st.expander("View Raw Board Member Results"):
                            st.json(raw_results)  # Display raw results JSON

                    # Display any synthesis errors
                    if "ai_board_synthesis_error" in clip:
                        st.error(f"Synthesis Error: {clip['ai_board_synthesis_error']}")

                elif "ai_board_error" in clip:
                    st.error(
                        f"AI Board Analysis Failed for this clip: {clip['ai_board_error']}"
                    )
                    # Optionally show raw error details if stored

                else:
                    st.info("AI Board analysis has not been run for this clip yet.")

                st.markdown("---")  # Separator at the end of the expander content

    async def close(self):
        """Close any resources held by the AI module (e.g., client connections)."""
        await self.model_manager.close()
        logger.info("AIAnalysisModule resources closed.")
