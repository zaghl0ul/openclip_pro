import streamlit as st
import datetime
import os
import time
import logging  # Import logging

from database import load_projects, delete_project
from media_utils import cleanup_project_directories

logger = logging.getLogger(__name__)


def show():
    """Display the Projects page with List and Gallery views."""
    st.title("📁 Projects")

    # Load project headers, which now include top clip thumbnail and score
    projects = load_projects()

    if not projects:
        st.info("No projects found. Create a new project to get started!", icon="💡")
        if st.button("➕ Create New Project"):
            st.session_state.app_mode = "🎬 Create New"
            st.rerun()
        return

    # --- Filtering and Sorting ---
    col_search, col_sort, col_view = st.columns([2, 1, 1])
    with col_search:
        search_term = st.text_input(
            "Search by Name",
            "",
            key="project_search",
            placeholder="Enter project name...",
        )
    with col_sort:
        # Add options for sorting by top clip score
        sort_options = [
            "Newest First",
            "Oldest First",
            "Name (A-Z)",
            "Clip Count",
            "Top Score (High-Low)",
            "Top Score (Low-High)",
        ]
        # Initialize sort_by in session state if not exists
        if "projects_list_sort_by" not in st.session_state:
            st.session_state.projects_list_sort_by = "Newest First"
        sort_by = st.selectbox(
            "Sort by",
            sort_options,
            index=sort_options.index(st.session_state.projects_list_sort_by),
            key="project_sort_select",
        )
        st.session_state.projects_list_sort_by = sort_by  # Update session state

    with col_view:
        view_options = ["List", "Gallery"]
        # Initialize view_mode in session state if not exists
        if "projects_list_view_mode" not in st.session_state:
            st.session_state.projects_list_view_mode = "List"  # Default to List
        view_mode_val = st.session_state.projects_list_view_mode
        view_index = view_options.index(view_mode_val)

        view_mode = st.radio(
            "View As",
            view_options,
            index=view_index,
            horizontal=True,
            key="project_view_mode_radio",
        )
        # Update session state if changed
        if view_mode != view_mode_val:
            st.session_state.projects_list_view_mode = view_mode
            st.rerun()  # Rerun to apply the new view mode

    # Apply filtering
    filtered_projects = projects
    if search_term:
        filtered_projects = [
            p
            for p in filtered_projects
            if search_term.lower() in p.get("name", "").lower()
        ]

    # Apply sorting
    sort_key_func = lambda x: x.get("created_at", "")  # Default to created_at
    reverse_sort = True  # Default to newest first

    if sort_by == "Oldest First":
        reverse_sort = False
    elif sort_by == "Name (A-Z)":
        sort_key_func = lambda x: x.get("name", "").lower()  # Case-insensitive sort
        reverse_sort = False
    elif sort_by == "Clip Count":
        sort_key_func = lambda x: x.get("clip_count", 0)
        reverse_sort = True  # More clips first
    elif sort_by == "Top Score (High-Low)":
        sort_key_func = lambda x: x.get(
            "top_clip_score", 0
        )  # Use top_clip_score from header
        reverse_sort = True
    elif sort_by == "Top Score (Low-High)":
        sort_key_func = lambda x: x.get("top_clip_score", 0)
        reverse_sort = False

    # Handle potential None values during sort by providing defaults (0 or empty string)
    try:
        filtered_projects.sort(key=sort_key_func, reverse=reverse_sort)
    except Exception as e:
        logger.error(f"Error during project list sorting: {e}", exc_info=True)
        st.warning(f"Error applying sort order: {e}")  # Inform the user

    st.caption(f"Showing {len(filtered_projects)} of {len(projects)} projects.")
    st.markdown("---")

    if not filtered_projects:
        st.info("No projects match your current filters or search criteria.")
        return

    # --- Display Projects ---
    # Use the stored view mode from session state
    if st.session_state.projects_list_view_mode == "List":
        st.subheader("Project List")
        # Use columns for a list layout
        for project_header in filtered_projects:
            pid = project_header["id"]
            pname = project_header["name"]
            pdir = project_header["base_dir_path"]  # Needed for cleanup
            clip_count = project_header.get("clip_count", 0)
            source_type = project_header.get("source_type", "N/A").capitalize()
            created_at = project_header.get("created_at")
            created_str = "Unknown"
            if created_at:
                try:
                    created_str = datetime.datetime.fromisoformat(created_at).strftime(
                        "%Y-%m-%d %H:%M"
                    )
                except (ValueError, TypeError):
                    pass  # Handle potential errors

            # Get top clip info directly from the header returned by load_projects
            top_clip_thumbnail = project_header.get("top_clip_thumbnail")
            top_clip_score = project_header.get("top_clip_score", 0)

            item_cols = st.columns([1, 3, 1, 1])  # Adjust column ratios as needed
            with item_cols[0]:
                # Display thumbnail from header data
                if top_clip_thumbnail and os.path.exists(top_clip_thumbnail):
                    try:
                        # Use a small fixed width for consistency
                        st.image(top_clip_thumbnail, width=100)
                    except Exception:
                        st.caption("Preview Err")  # Show error if image fails to load
                else:
                    st.caption("No Preview")  # Placeholder if no thumbnail

            with item_cols[1]:
                st.markdown(f"**{pname}**")
                st.caption(f"Created: {created_str} | Source: {source_type}")
                st.caption(
                    f"Clips: {clip_count} | Top Score: {top_clip_score if clip_count > 0 else 'N/A'}"
                )

            with item_cols[2]:
                # Button to open project details - sets session state and reruns
                if st.button("Open", key=f"open_list_{pid}", use_container_width=True):
                    st.session_state.current_project_id = pid
                    # Main app router will handle navigating to project_details_page
                    st.rerun()
            with item_cols[3]:
                # Button to initiate delete confirmation - sets session state and reruns
                if st.button(
                    "Delete",
                    key=f"delete_list_{pid}",
                    type="secondary",
                    use_container_width=True,
                ):
                    # Use confirmation pattern unique to the list page
                    st.session_state.confirm_delete_list = {
                        "id": pid,
                        "name": pname,
                        "dir": pdir,
                    }
                    st.rerun()

            st.markdown("---")  # Separator for list items

        # Handle list deletion confirmation - displayed above the list loop if active
        # This ensures the confirmation dialog appears prominently.
        if st.session_state.get("confirm_delete_list"):
            project_info = st.session_state.confirm_delete_list
            pid = project_info["id"]
            pname = project_info["name"]
            pdir = project_info["dir"]  # Directory path for cleanup

            st.warning(f"⚠️ Confirm permanent deletion of project '{pname}'?")
            st.caption(
                "This action is irreversible and will delete the database entry and associated files."
            )
            confirm_cols = st.columns(2)
            with confirm_cols[0]:
                if st.button(
                    "✅ Yes, Delete", key=f"confirm_del_list_yes_{pid}", type="primary"
                ):
                    logger.info(
                        f"User confirmed deletion for project {pid} from Project List."
                    )
                    deleted_db = delete_project(pid)  # Delete from DB
                    deleted_files = cleanup_project_directories(pdir)  # Cleanup files

                    if deleted_db:
                        st.success(f"Project '{pname}' deleted from database.")
                    else:
                        st.error("Failed to delete project from database.")
                    # cleanup_project_directories logs its own success/failure messages

                    st.session_state.confirm_delete_list = (
                        None  # Clear confirmation flag
                    )
                    # Add a small delay before rerun so the user can see the message
                    time.sleep(1)
                    st.rerun()  # Rerun to refresh the list

            with confirm_cols[1]:
                if st.button("❌ Cancel", key=f"confirm_del_list_no_{pid}"):
                    logger.info(
                        f"User cancelled deletion for project {pid} from Project List."
                    )
                    st.session_state.confirm_delete_list = None
                    st.rerun()

    elif st.session_state.projects_list_view_mode == "Gallery":
        st.subheader("Project Gallery")
        cols = st.columns(4)  # Adjust number of columns as needed
        col_index = 0

        # Handle gallery deletion confirmation - display prominently
        if st.session_state.get("confirm_delete_gallery"):
            project_info = st.session_state.confirm_delete_gallery
            pid = project_info["id"]
            pname = project_info["name"]
            pdir = project_info["dir"]

            st.warning(f"⚠️ Confirm permanent deletion of project '{pname}'?")
            st.caption(
                "This action is irreversible and will delete the database entry and associated files."
            )
            confirm_cols = st.columns(2)
            with confirm_cols[0]:
                if st.button(
                    "✅ Yes, Delete", key=f"confirm_del_gal_yes_{pid}", type="primary"
                ):
                    logger.info(
                        f"User confirmed deletion for project {pid} from Gallery."
                    )
                    deleted_db = delete_project(pid)
                    deleted_files = cleanup_project_directories(pdir)

                    if deleted_db:
                        st.success(f"Project '{pname}' deleted from database.")
                    else:
                        st.error("Failed to delete project from database.")

                    st.session_state.confirm_delete_gallery = None
                    time.sleep(1)
                    st.rerun()
            with confirm_cols[1]:
                if st.button("❌ Cancel", key=f"confirm_del_gal_no_{pid}"):
                    logger.info(
                        f"User cancelled deletion for project {pid} from Gallery."
                    )
                    st.session_state.confirm_delete_gallery = None
                    st.rerun()

            # Stop gallery rendering while confirmation is up
            return

        # Render gallery items
        for project_header in filtered_projects:
            pid = project_header["id"]
            pname = project_header["name"]
            pdir = project_header["base_dir_path"]
            clip_count = project_header.get("clip_count", 0)
            created_at = project_header.get("created_at")
            created_str = "Unknown"
            if created_at:
                try:
                    created_str = datetime.datetime.fromisoformat(created_at).strftime(
                        "%Y-%m-%d"
                    )
                except (ValueError, TypeError):
                    pass

            # Get top clip info from header
            top_clip_thumbnail = project_header.get("top_clip_thumbnail")
            top_clip_score = project_header.get("top_clip_score", 0)

            # Place the project card in the current column
            with cols[col_index % len(cols)]:
                # Use a container with a border for card-like appearance
                with st.container(border=True):
                    st.markdown(f"**{pname}**")
                    # Display thumbnail from header data
                    if top_clip_thumbnail and os.path.exists(top_clip_thumbnail):
                        try:
                            # Use use_column_width=True for gallery view
                            st.image(top_clip_thumbnail, use_column_width=True)
                        except Exception:
                            st.caption("Preview Err")
                    else:
                        # Placeholder if no thumbnail
                        st.caption("No Preview")

                    st.caption(
                        f"Clips: {clip_count} | Top: {top_clip_score if clip_count > 0 else 'N/A'} | {created_str}"
                    )

                    # Buttons below the info
                    btn_cols = st.columns(2)
                    with btn_cols[0]:
                        # Open button
                        if st.button(
                            "Open", key=f"open_gal_{pid}", use_container_width=True
                        ):
                            st.session_state.current_project_id = pid
                            st.rerun()
                    with btn_cols[1]:
                        # Delete button (triggers confirmation)
                        if st.button(
                            "Del",
                            key=f"delete_gal_{pid}",
                            type="secondary",
                            use_container_width=True,
                            help="Delete Project",
                        ):
                            # Use confirmation pattern unique to the gallery page
                            st.session_state.confirm_delete_gallery = {
                                "id": pid,
                                "name": pname,
                                "dir": pdir,
                            }
                            st.rerun()
            col_index += 1  # Move to the next column

    st.divider()
    # Add a "Create New Project" button at the bottom of the page as well
    if st.button("➕ Create New Project ", key="create_new_btn_bottom"):
        st.session_state.app_mode = "🎬 Create New"
        st.rerun()
